# Feature Dynamics Configuration
# Copy this file to .env and update with your paths

# Directory for cached datasets (SAE activations, trial data, etc.)
FEATURE_DYNAMICS_CACHE_DIR=/path/to/your/cache

# Directory for outputs (trained models, results, plots)
FEATURE_DYNAMICS_OUTPUT_DIR=/path/to/your/outputs

# Optional: Hugging Face model path (if using local model)
# GEMMA_MODEL_PATH=/path/to/gemma-3-27b-it
